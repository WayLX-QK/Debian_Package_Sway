#!/bin/sh
# postrm script for sway-config-debian
set -e

PACKAGE="sway-config-debian"
TARGET_FILE="/etc/sway/config"
DIVERT_TO="/etc/sway/config.distrib"

remove_diversion() {
    # 严谨检查：确认该偏转确实由本包发起
    if dpkg-divert --list --package "$PACKAGE" --divert "$DIVERT_TO" "$TARGET_FILE" | grep -q "$PACKAGE"; then
        echo "Removing diversion for $TARGET_FILE by $PACKAGE..."
        # 恢复原始文件：将 .distrib 重命名回原名，并删除偏转记录
        dpkg-divert --package "$PACKAGE" --remove --rename \
            --divert "$DIVERT_TO" "$TARGET_FILE"
    fi
}

case "$1" in
    remove|abort-install|disappear)
        # 当包被移除、安装中止或被替换时，必须撤销劫持
        remove_diversion
    ;;

    purge)
        # 彻底清除时再次确保记录被清理（防止 remove 阶段出现意外）
        remove_diversion
    ;;

    upgrade|failed-upgrade|abort-upgrade)
        # 升级过程中绝对不要移除偏转记录！
        # 否则会导致新旧版本交替时文件系统状态不稳定
    ;;

    *)
    ;;
esac

#DEBHELPER#

exit 0
