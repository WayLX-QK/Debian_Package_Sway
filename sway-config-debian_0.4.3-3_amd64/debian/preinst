#!/bin/sh
# preinst script for sway-config-debian.
#
# See: dh_installdeb(1).

set -e

# Summary of how this script can be called:
#        * <new-preinst> 'install'
#        * <new-preinst> 'install' <old-version>
#        * <new-preinst> 'upgrade' <old-version>
#        * <old-preinst> 'abort-upgrade' <new-version>
# for details, see https://www.debian.org/doc/debian-policy/ or
# the debian-policy package.

set -e

if [ "$1" = "install" ] || [ "$1" = "upgrade" ]; then
    # 通知 dpkg 系统：将官方 sway 写入的 /etc/sway/config 自动偏转重命名为 .distrib 备份，
    # 并将所有权临时交予我们的 sway-config-debian 包。
    dpkg-divert --package sway-config-debian --add --rename \
        --divert /etc/sway/config.distrib /etc/sway/config
fi

# dh_installdeb will replace this with shell code automatically
# generated by other debhelper scripts.

#DEBHELPER#

exit 0
