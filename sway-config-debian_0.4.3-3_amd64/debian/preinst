#!/bin/sh
# preinst script for sway-config-debian
set -e

PACKAGE="sway-config-debian"
TARGET_FILE="/etc/sway/config"
DIVERT_TO="/etc/sway/config.distrib"

# 定义执行偏转的函数，增强可读性
add_diversion() {
    # 预检查：只有当系统中不存在该偏转时才执行
    # 使用 --quiet 减少不必要的输出，使用 --list 检查状态
    if ! dpkg-divert --list --package "$PACKAGE" --divert "$DIVERT_TO" "$TARGET_FILE" | grep -q "$PACKAGE"; then
        echo "Adding diversion for $TARGET_FILE by $PACKAGE..."
        dpkg-divert --package "$PACKAGE" --add --rename \
            --divert "$DIVERT_TO" "$TARGET_FILE"
    fi
}

case "$1" in
    install|upgrade)
        # 无论是新安装还是升级，都确保偏转逻辑到位
        add_diversion
    ;;

    abort-upgrade)
        # 如果升级失败回滚，通常不需要额外操作，因为偏转逻辑应该已经在之前版本中存在
    ;;

    *)
        # 其他未知参数不做处理
    ;;
esac

#DEBHELPER#

exit 0
